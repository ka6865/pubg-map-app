{
  "name": "pubg-map-app",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "jest",
    "test:unit": "vitest run",
    "test:ai:gemini": "RUN_REAL_GEMINI=true vitest run tests/ai-coaching-gemini.integration.test.ts --testTimeout=60000",
    "test:ai:report": "tsx scripts/check_ai_coaching_report.ts --require-default-suite --require-raw-quality",
    "test:ai:report:real": "tsx scripts/check_ai_coaching_report.ts --file tmp/ai-coaching-real-data-report.json --require-real-suite --require-raw-quality",
    "test:ai:real-data": "tsx scripts/audit_ai_coaching_real_data.ts",
    "test:ai:audit": "tsx scripts/write_ai_coaching_report_summary.ts --require-default-suite --require-raw-quality",
    "test:ai:audit:real": "tsx scripts/write_ai_coaching_report_summary.ts --file tmp/ai-coaching-real-data-report.json --output tmp/ai-coaching-real-data-audit.md --require-real-suite --require-raw-quality",
    "verify:core": "eslint && tsc --noEmit --pretty false",
    "verify:analysis": "vitest run tests/analysis-engine.test.ts tests/pubg-analysis-stability.test.ts tests/squad-recovery-stats.test.ts tests/squad-cause-scenes.test.ts tests/ai-cache-routes.test.ts tests/persist-match-analysis.test.ts tests/pubg-ingest-boundary.test.ts tests/hotdrop-job.test.ts tests/hotdrop-script.test.ts tests/hotdrop-boundary.test.ts",
    "verify:admin": "vitest run tests/admin-agent-api.test.ts tests/admin-agent-data-quality.test.ts tests/analytics-event.test.ts tests/admin-agent-user-metrics.test.ts tests/security.test.ts",
    "build:app": "bash scripts/build-app.sh",
    "db:cleanup": "tsx scripts/cleanup_telemetry.ts",
    "db:audit:identity": "tsx scripts/audit_processed_telemetry_identity.ts",
    "db:scrape": "tsx scripts/scrape_elite.ts"
  },
  "dependencies": {
    "@ai-sdk/google": "^3.0.64",
    "@aws-sdk/client-s3": "^3.1048.0",
    "@aws-sdk/s3-request-presigner": "^3.1048.0",
    "@emnapi/core": "1.10.0",
    "@emnapi/runtime": "1.10.0",
    "@google/generative-ai": "^0.24.1",
    "@next/third-parties": "^16.2.4",
    "@supabase/ssr": "^0.10.0",
    "@supabase/supabase-js": "^2.95.3",
    "@types/bcryptjs": "^2.4.6",
    "@types/three": "^0.184.1",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "ai": "^6.0.168",
    "axios": "^1.15.2",
    "bcryptjs": "^3.0.3",
    "browser-image-compression": "^2.0.2",
    "discord.js": "^14.26.2",
    "dompurify": "^3.3.1",
    "dotenv": "^17.4.2",
    "html-to-image": "^1.11.13",
    "jsonrepair": "^3.14.0",
    "leaflet": "^1.9.4",
    "leaflet.heat": "^0.2.0",
    "lucide-react": "^0.562.0",
    "next": "16.1.1",
    "node-html-parser": "^7.1.0",
    "puppeteer": "^25.1.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-leaflet": "^5.0.0",
    "react-quill-new": "^3.8.3",
    "sharp": "^0.34.5",
    "sonner": "^2.0.7",
    "three": "^0.184.0",
    "vaul": "^1.1.2"
  },
  "devDependencies": {
    "@capacitor/android": "^8.3.0",
    "@capacitor/assets": "^3.0.5",
    "@capacitor/cli": "^8.3.0",
    "@capacitor/core": "^8.3.0",
    "@capacitor/ios": "^8.3.0",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/dompurify": "^3.0.5",
    "@types/jest": "^30.0.0",
    "@types/leaflet": "^1.9.21",
    "@types/leaflet.heat": "^0.2.5",
    "@types/lodash": "^4.17.24",
    "@types/node": "^20.19.39",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9",
    "eslint-config-next": "16.1.1",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.2.0",
    "tailwindcss": "^4",
    "ts-jest": "^29.4.6",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^4.1.5"
  }
}
